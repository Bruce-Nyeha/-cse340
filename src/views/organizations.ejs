<%- include('partials/header') %>

<main class="orgs-main-container">
    <h1 class="page-title">Our Partner Organizations</h1>
    <div class="orgs-grid-wrapper">
        
        <% if (locals.organizations && organizations.length > 0) { %>
            <% organizations.forEach(org => { 
                /* Directly forces filenames to align perfectly with your sidebar file list */
                let finalImageFile = "default-logo.png";
                let checkName = (org.name || org.organization_name || "").toLowerCase();
                
                if (checkName.includes("brightfuture")) {
                    finalImageFile = "brightfuture-logo.png";
                } else if (checkName.includes("greenharvest")) {
                    finalImageFile = "greenharvest-logo.png";
                } else if (checkName.includes("unityserve")) {
                    finalImageFile = "unityserve-logo.png";
                }
            %>
                <div class="org-card-item">

                    <h3 class="org-card-title">
                        <a href="/organization/<%= org.organization_id %>" style="color: #0056b3; text-decoration: none; font-weight: 700;">
                            <%= org.name || org.organization_name || "Partner Organization" %>
                        </a>
                    </h3>
                    
                    <div class="org-logo-box">
                        
                        <a href="/organization/<%= org.organization_id %>">
                            <img class="org-card-logo" src="/images/<%= finalImageFile %>" alt="Organization Logo">
                        </a>
                    </div>
                    
                    <p class="org-card-description"><%= org.description || "A dedicated community organization supporting local outreach initiatives." %></p>
                    
                    <p class="org-card-contact">
                        <strong>Email:</strong> <a href="mailto:<%= org.email || org.organization_email %>"><%= org.email || org.organization_email || "contact@service.org" %></a>
                    </p>
                </div>
            <% }) /* Closes the forEach loop safely */ %>
        <% } else { %>
            <p>No organizations found in the database.</p>
        <% } /* Closes the if statement safely */ %>
        
    </div>
</main>

<%- include('partials/footer') %>
