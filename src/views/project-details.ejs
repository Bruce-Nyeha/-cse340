<%- include('partials/header') %>

<main class="details-main-container">
    <h1 class="details-title"><%= project.title %></h1>
    
    <div class="details-card">
        <p class="details-date">
            <strong>Date:</strong> 
            <%= new Date(project.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' }) %>
        </p>
        
        <p class="details-org">
            <strong>Sponsored By:</strong> 
            <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
        </p>
        
        <p class="details-location"><strong>Location:</strong> <%= project.location %></p>
        
        <p class="details-description"><strong>Description:</strong> <%= project.description %></p>
        
        <!-- Category Tags Section Required by Step 6 -->
        <div class="tags-container">
            <strong>Categories:</strong>
            <% if (categories && categories.length > 0) { %>
                <% categories.forEach(cat => { %>
                    <a href="/category//<%= cat.category_id %>" class="category-tag-link"><%= cat.category_name %></a>
                <% }); %>
            <% } else { %>
                <span>Uncategorized</span>
            <% } %>
        </div>
    </div>
    
    <a href="/projects" class="back-link">← Back to All Projects</a>
</main>

<%- include('partials/footer') %>
